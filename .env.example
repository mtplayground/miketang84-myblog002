# PostgreSQL connection string used for all persistent state.
DATABASE_URL=postgresql://username:password@hostname:5432/database?sslmode=require

# Auth.js / NextAuth secret. Use a long random value in real deployments.
NEXTAUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Env-based admin credentials for the initial credentials provider setup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$replace-with-a-bcrypt-password-hash

# Object storage configuration for image uploads.
S3_BUCKET=myblog002-assets
S3_REGION=auto
S3_ACCESS_KEY=replace-with-s3-access-key
S3_SECRET_KEY=replace-with-s3-secret-key
S3_ENDPOINT=https://s3.example.com
S3_PUBLIC_URL=https://cdn.example.com
S3_FORCE_PATH_STYLE=false

# Canonical public URL for metadata, feeds, and callbacks.
SITE_URL=https://example.com

# Optional about-page overrides. Leave unset to use content/about.md.
ABOUT_TITLE=About
ABOUT_HEADING=A short intro for the about page
ABOUT_BIO_MARKDOWN=Write the about page in markdown if you do not want to ship content/about.md
